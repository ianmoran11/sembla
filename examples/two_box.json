{
  "name": "two_box_feedback",
  "dt": 1.0,
  "params": [],
  "boxes": [
    {
      "name": "population",
      "tables": [
        {
          "name": "Person",
          "size_hint": 16,
          "attrs": [
            { "name": "health", "ty": { "kind": "enum", "variants": ["Healthy", "Infected"] } },
            { "name": "group", "ty": { "kind": "ref", "table": "Group" } }
          ]
        },
        { "name": "Group", "size_hint": 1, "attrs": [] }
      ],
      "transitions": [
        {
          "name": "infect",
          "table": "Person",
          "guard": { "kind": "enum_is", "attr": "health", "variant": "Healthy" },
          "hazard": {
            "kind": "mul",
            "lhs": {
              "kind": "input",
              "port": "control",
              "agg": {
                "op": { "kind": "sum", "value": { "kind": "self_attr", "name": "modifier" } },
                "filter": {
                  "kind": "gt",
                  "lhs": { "kind": "self_attr", "name": "modifier" },
                  "rhs": { "kind": "real", "value": 0.0 }
                }
              }
            },
            "rhs": { "kind": "real", "value": 1e300 }
          },
          "effects": [
            { "kind": "set_attr", "attr": "health", "value": { "kind": "enum", "variant": "Infected" } }
          ],
          "contests": []
        }
      ],
      "inputs": [
        { "name": "control", "schema": [{ "name": "modifier", "ty": { "kind": "real" } }] }
      ],
      "outputs": [
        {
          "name": "infection",
          "schema": [{ "name": "infected", "ty": { "kind": "int" } }],
          "builder": {
            "kind": "per_table",
            "table": "Person",
            "fields": [
              {
                "name": "infected",
                "op": { "kind": "count" },
                "filter": { "kind": "enum_is", "attr": "health", "variant": "Infected" }
              }
            ]
          }
        }
      ]
    },
    {
      "name": "controller",
      "tables": [
        {
          "name": "Controller",
          "size_hint": 1,
          "attrs": [
            { "name": "modifier", "ty": { "kind": "real" } },
            { "name": "group", "ty": { "kind": "ref", "table": "Group" } }
          ]
        },
        { "name": "Group", "size_hint": 1, "attrs": [] }
      ],
      "transitions": [
        {
          "name": "enable",
          "table": "Controller",
          "guard": {
            "kind": "or",
            "lhs": {
              "kind": "lt",
              "lhs": { "kind": "self_attr", "name": "modifier" },
              "rhs": { "kind": "real", "value": 0.5 }
            },
            "rhs": {
              "kind": "gt",
              "lhs": {
                "kind": "input",
                "port": "infection",
                "agg": {
                  "op": { "kind": "count" },
                  "filter": {
                    "kind": "gt",
                    "lhs": { "kind": "self_attr", "name": "infected" },
                    "rhs": { "kind": "int", "value": 0 }
                  }
                }
              },
              "rhs": { "kind": "int", "value": 0 }
            }
          },
          "hazard": { "kind": "real", "value": 1e300 },
          "effects": [
            { "kind": "set_attr", "attr": "modifier", "value": { "kind": "real", "value": 1.0 } }
          ],
          "contests": []
        }
      ],
      "inputs": [
        { "name": "infection", "schema": [{ "name": "infected", "ty": { "kind": "int" } }] }
      ],
      "outputs": [
        {
          "name": "control",
          "schema": [{ "name": "modifier", "ty": { "kind": "real" } }],
          "builder": {
            "kind": "per_table",
            "table": "Controller",
            "fields": [
              {
                "name": "modifier",
                "op": { "kind": "sum", "value": { "kind": "self_attr", "name": "modifier" } },
                "filter": null
              }
            ]
          }
        }
      ]
    }
  ],
  "wires": [
    { "from": { "box": "population", "port": "infection" }, "to": { "box": "controller", "port": "infection" } },
    { "from": { "box": "controller", "port": "control" }, "to": { "box": "population", "port": "control" } }
  ]
}
